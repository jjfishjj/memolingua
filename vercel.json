{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Permissions-Policy", "value": "bluetooth=(self)" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
